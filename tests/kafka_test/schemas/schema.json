{
    "type": "record",
    "name": "TelegramMessage_test",
    "namespace": "com.telegram.ingestion",
    "fields": [
        {
            "name": "type",
            "type": "string",
            "doc": "Message type: text, audio, photo, or document"
        },
        {
            "name": "content",
            "type": "string",
            "doc": "Extracted text content or transcribed audio"
        },
        {
            "name": "message_id",
            "type": "long",
            "doc": "Unique message identifier from Telegram"
        },
        {
            "name": "chat_id",
            "type": "long",
            "doc": "Telegram chat/channel ID"
        },
        {
            "name": "date",
            "type": "string",
            "doc": "Message timestamp in ISO 8601 format"
        },
        {
            "name": "user_id",
            "type": ["null", "long"],
            "default": null,
            "doc": "Telegram user ID"
        },
        {
            "name": "user_name",
            "type": ["null", "string"],
            "default": null,
            "doc": "Telegram username"
        },
        {
            "name": "reply_to",
            "type": ["null", "long"],
            "default": null,
            "doc": "Message ID this message is replying to"
        },
        {
            "name": "file_id",
            "type": ["null", "string"],
            "default": null,
            "doc": "Telegram file identifier (for audio, photo, document)"
        },
        {
            "name": "mime_type",
            "type": ["null", "string"],
            "default": null,
            "doc": "MIME type of media file (for audio, photo, document)"
        },
        {
            "name": "file_name",
            "type": ["null", "string"],
            "default": null,
            "doc": "Document file name"
        },
        {
            "name": "duration",
            "type": ["null", "int"],
            "default": null,
            "doc": "Audio duration in seconds"
        }
    ]
}